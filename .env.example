# Environment selection: development | production | staging | qa
APP_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/form_dev
# For Docker Compose, use:
# MONGODB_URI=mongodb://formadmin:<password>@mongo:27017/form_prod?authSource=admin
MONGODB_DB=form_dev
MONGODB_CONNECT_TIMEOUT_MS=2000
MONGO_INITDB_ROOT_USERNAME=formadmin
MONGO_INITDB_ROOT_PASSWORD=<generate-a-strong-password>

# Required in production. Optional in development (fallback warning is used if empty).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-with-python-secrets.token_hex-32>
JWT_ACTIVE_KID=v1
# Optional old keys for phased rotation: kid:secret pairs separated by commas
# JWT_ADDITIONAL_KEYS=v0:old-secret
JWT_ALGORITHM=HS256

# Token TTLs
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# Auth endpoint rate limits
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_MAX=20
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_LOGOUT_MAX=20
AUTH_RATE_LIMIT_LOGOUT_WINDOW_SECONDS=60
RESOURCE_RATE_LIMIT_MAX=300
RESOURCE_RATE_LIMIT_WINDOW_SECONDS=60
# Set to false to fail closed when the Redis-backed rate limiter is unavailable
RATE_LIMIT_FAIL_OPEN=true

# Superadmin Seeding (Runs on app startup)
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=admin123

# RBAC and workflow behaviour
# Set to false to allow project members without a matching org role
RESOURCE_RBAC_REQUIRE_ORG_ROLE_ALIGNMENT=true
# Set to false to skip the in_review step before approve
WORKFLOW_STRICT_REVIEW_BEFORE_APPROVE=true

# Audit logs and security events
ENABLE_AUDIT_LOGS=true
# Retention period for session_audit_logs TTL index (days)
AUDIT_LOG_RETENTION_DAYS=180

# API versioning
API_VERSION=v1

# Structured logging
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Celery async execution
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# For Docker Compose, use:
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_DEFAULT_QUEUE=form_tasks
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=false

# Monitoring retention
MONITORING_STATS_RETENTION_DAYS=30

# HTTP behaviour and hardening
# Comma-separated list, for example:
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=
ENABLE_COMPRESSION=true
REQUEST_ID_HEADER=X-Request-Id

# Docker / Compose
# Copy this file to `.env` and adjust the values for your local or production stack.
