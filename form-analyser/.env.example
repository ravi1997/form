# MongoDB connection
MONGO_URI=mongodb://localhost:27017/form_analyser
MONGO_DB_NAME=form_analyser

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Collection names
FORM_RESPONSES_COLLECTION=form_responses
ANALYSIS_DEFINITIONS_COLLECTION=analysis_definitions
ANALYSIS_RESULTS_COLLECTION=analysis_results
API_KEYS_COLLECTION=api_keys

# Auth — set to False to disable API key checks during local development
AUTH_ENABLED=True
