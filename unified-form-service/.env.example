# ==============================================================================
# Unified Form Service - Consolidated Environment Variables Template (.env.example)
#
# This file consolidates configuration settings for all three sub-services:
#   1. Form Builder
#   2. Response Gateway (Form Response)
#   3. Form Analyser
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Flask & Core App Environment
# ------------------------------------------------------------------------------
# Flask application environment (development, production, testing)
FLASK_ENV=development

# Enable or disable debug mode (True/False or 1/0)
FLASK_DEBUG=True

# Identifier for the Response Gateway microservice instance
SERVICE_NAME=form-response-service


# ------------------------------------------------------------------------------
# 2. Database & Cache Configurations
# ------------------------------------------------------------------------------
# Primary MongoDB connection URI (shared by Builder and Analyser)
MONGO_URI=mongodb://localhost:27017/

# Form Builder database name
DB_NAME=form_builder_db

# Form Analyser database name
MONGO_DB_NAME=form_analyser

# Response Gateway database connection URL. Note that RESPONSE_DATABASE_URL and
# DATABASE_URL are used interchangeably/redundantly by the response gateway.
DATABASE_URL=mongodb://localhost:27017/form_response
RESPONSE_DATABASE_URL=mongodb://mongodb:27017/form_response

# Redis connection URL (used by Analyser for caching & scheduling queues)
REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------------------------
# 3. Security, Authentication & Cryptography
# ------------------------------------------------------------------------------
# Core Flask secret key for session signing
SECRET_KEY=super-secret-key-change-in-prod

# JWT Secret key for Builder user token verification
JWT_SECRET=super-secret-key-change-in-prod

# Password salt for hashing User passwords in Form Builder
PASSWORD_SALT=secure-system-salt-key-change

# Encryption keys used for encrypting sensitive form fields
SECRET_ENCRYPTION_KEY=your-single-encryption-key-here
SECRET_ENCRYPTION_KEYS=your-comma-separated-encryption-keys-here

# Authentication guards toggle:
# - REQUIRE_AUTH: controls access to Builder endpoints (true/false)
# - AUTH_ENABLED: controls API key checks on Analyser endpoints (True/False)
REQUIRE_AUTH=false
AUTH_ENABLED=True


# ------------------------------------------------------------------------------
# 4. Multi-Tenant Database Settings (Form Builder)
# ------------------------------------------------------------------------------
# Enable MongoDB database-per-organization isolation (true/false)
TENANT_DB_ISOLATION=false

# Max active database connections cached in pool for tenants
ACTIVE_DB_LIMIT=5

# Idle connection timeout in seconds before closing tenant database connections
DB_INACTIVE_TIMEOUT=300

# Note: If TENANT_DB_ISOLATION=true, custom organization-specific connection strings
# can be defined dynamically using the format: MONGO_URI_<ORG_ID>
# E.g., MONGO_URI_org123=mongodb://localhost:27017/org123_db


# ------------------------------------------------------------------------------
# 5. File Storage & S3 Settings (Form Builder)
# ------------------------------------------------------------------------------
# Directory path for local file uploads (fallback if S3 is not configured)
UPLOAD_FOLDER=static/uploads

# S3/MinIO Object Storage configuration
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=form-uploads
S3_REGION_NAME=us-east-1


# ------------------------------------------------------------------------------
# 6. MongoDB Collection Settings (Form Analyser)
# ------------------------------------------------------------------------------
FORMS_COLLECTION=forms
FORM_RESPONSES_COLLECTION=form_responses
ANALYSIS_DEFINITIONS_COLLECTION=analysis_definitions
ANALYSIS_RESULTS_COLLECTION=analysis_results
API_KEYS_COLLECTION=api_keys
WEBHOOKS_COLLECTION=webhooks


# ------------------------------------------------------------------------------
# 7. Integration & Synchronization Settings
# ------------------------------------------------------------------------------
# Synchronization mode for response gateway forwarding submissions to analyser (local/remote)
ANALYSER_SYNC_MODE=local

# ------------------------------------------------------------------------------
# 8. Docker Port Configuration (optional overrides)
# ------------------------------------------------------------------------------
# Change these if you have port conflicts on your machine.
# These are used by both docker-compose.yml and docker-compose.dev.yml.

APP_PORT=5000
MONGO_PORT=27017
REDIS_PORT=6379

# Dev tooling ports (docker-compose.dev.yml only)
MONGO_EXPRESS_PORT=8081
REDIS_COMMANDER_PORT=8082
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
JAEGER_PORT=16686
PORTAINER_PORT=9443
LOCUST_PORT=8089

# ------------------------------------------------------------------------------
# 9. Dev Tooling Credentials (docker-compose.dev.yml only)
# ------------------------------------------------------------------------------
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=devpassword

# MinIO root credentials (used by MinIO server and mc init container)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Mail settings (Mailhog in dev, real SMTP in prod)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@unified-form-service.local
